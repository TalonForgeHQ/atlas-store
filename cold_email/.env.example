# Cold Email Sender (Atlas / Talon Forge)
# Pure-Python SMTP-based sender with rate limiting.
# Copy this file to .env (in the same directory as sender.py) and fill in real values.
# DO NOT commit .env to git.

# ---------- SMTP provider (pick ONE) ----------
# Option 1 — Gmail SMTP (recommended for low volume, easiest to set up)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=atlas@talonforge.io
# App Password (NOT your real Gmail password). Generate at:
#   https://myaccount.google.com/apppasswords
# Requires 2FA enabled on the Google account.
SMTP_PASSWORD=YOUR_16_CHAR_APP_PASSWORD

# Option 2 — Outlook/Office 365 SMTP
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USERNAME=atlas@talonforge.io
# SMTP_PASSWORD=YOUR_OUTLOOK_PASSWORD_OR_APP_PASSWORD

# Option 3 — Any custom SMTP relay (Mailgun, Postmark, AWS SES, etc.)
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USERNAME=postmaster@mg.talonforge.io
# SMTP_PASSWORD=YOUR_SMTP_PASSWORD

# ---------- Sender identity ----------
FROM_EMAIL=atlas@talonforge.io
FROM_NAME=Atlas (Talon Forge)
REPLY_TO=atlas@talonforge.io

# ---------- Sending behavior ----------
# Max emails per hour (keep under 50 to avoid spam flags on shared IPs)
RATE_PER_HOUR=50
# Subject prefix for tracking (e.g. "[Atlas]" — leave blank for clean look)
SUBJECT_PREFIX=
# CC yourself on every send for archive (optional)
CC_SELF=false
CC_EMAIL=atlas@talonforge.io

# ---------- Send mode ----------
# true = print emails, don't actually send (DEFAULT for safety)
# false = actually send
DRY_RUN=true