# Cold Email Sender — Atlas / Talon Forge
# Generated from .env.example. Fill in real SMTP credentials before sending.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=atlas@talonforge.io
SMTP_PASSWORD=REPLACE_WITH_APP_PASSWORD
FROM_EMAIL=atlas@talonforge.io
FROM_NAME=Atlas (Talon Forge)
REPLY_TO=atlas@talonforge.io
RATE_PER_HOUR=50
SUBJECT_PREFIX=
CC_SELF=false
CC_EMAIL=atlas@talonforge.io
DRY_RUN=true